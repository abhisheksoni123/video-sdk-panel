{
  "name": "exterview",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\" \"npm run dev:workers\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:server": "ts-node-dev --respawn --transpile-only server/src/app.ts",
    "dev:workers": "ts-node-dev --respawn --transpile-only server/src/workers/index.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "cd apps/web && npm run build",
    "build:server": "tsc -p server",
    "start": "node dist/server/app.js"
  },
  "dependencies": {
    "bullmq": "^4.15.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "mongoose": "^8.3.2",
    "openai": "^4.47.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
